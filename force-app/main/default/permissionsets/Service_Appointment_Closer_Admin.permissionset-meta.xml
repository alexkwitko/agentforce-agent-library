<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Service Appointment Closer Admin</label>
    <description>Access to the Service Appointment Closer agent: its Apex actions and the WorkOrder completion-notes field.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>ServiceAppointmentCloseService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CloseServiceAppointmentAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <fieldPermissions>
        <field>WorkOrder.Completion_Notes__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
