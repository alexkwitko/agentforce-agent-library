<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Field Service Scheduler Admin</label>
    <description>Access to the Field Service Scheduler demo: the Apex actions and the two custom fields it relies on. Assign to yourself after install.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <classAccesses>
        <apexClass>OrderToFieldService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>FieldServiceSchedulingService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GetAppointmentSlotsAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>BookAppointmentAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <fieldPermissions>
        <field>Product2.Requires_Field_Service__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>WorkOrder.Source_Order_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
